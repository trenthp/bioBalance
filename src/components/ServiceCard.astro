---
interface Props {
  title: string;
  description: string;
  features: string[];
  href: string;
  delay?: number;
  icon?: string;
}

const { title, description, features, href, delay = 0, icon = 'default' } = Astro.props;

// Service icons mapping
const icons: Record<string, string> = {
  bhrt: `<circle cx="32" cy="32" r="28" stroke="url(#grad1)" stroke-width="2"/>
         <path d="M32 16c-8 0-14 6-14 14s6 18 14 18 14-10 14-18-6-14-14-14z" fill="url(#grad1)" opacity="0.2"/>
         <path d="M32 22c-4 0-8 4-8 8s4 12 8 12 8-8 8-12-4-8-8-8z" fill="url(#grad1)"/>`,
  menopause: `<circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="2"/>
              <path d="M24 28c0-4 3.5-8 8-8s8 4 8 8" stroke="currentColor" stroke-width="2"/>
              <circle cx="26" cy="24" r="2" fill="currentColor"/>
              <circle cx="38" cy="24" r="2" fill="currentColor"/>
              <path d="M24 38c2 3 5 4 8 4s6-1 8-4" stroke="currentColor" stroke-width="2"/>`,
  trt: `<path d="M32 8L8 20v24l24 12 24-12V20L32 8z" stroke="currentColor" stroke-width="2"/>
        <path d="M32 20L20 26v12l12 6 12-6V26l-12-6z" fill="currentColor" opacity="0.2"/>
        <path d="M32 44V32m0 0l12-6m-12 6L20 26" stroke="currentColor" stroke-width="2"/>`,
  thyroid: `<ellipse cx="32" cy="32" rx="20" ry="12" stroke="currentColor" stroke-width="2"/>
            <circle cx="32" cy="32" r="6" fill="currentColor" opacity="0.2"/>
            <circle cx="32" cy="32" r="3" fill="currentColor"/>`,
  pcos: `<circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="2"/>
         <circle cx="24" cy="28" r="4" fill="currentColor" opacity="0.3"/>
         <circle cx="40" cy="28" r="4" fill="currentColor" opacity="0.3"/>
         <circle cx="32" cy="40" r="6" fill="currentColor" opacity="0.3"/>`,
  'weight-loss': `<path d="M20 44V20h24v24H20z" stroke="currentColor" stroke-width="2"/>
                  <path d="M28 32h8M32 28v8" stroke="currentColor" stroke-width="2"/>
                  <path d="M16 48h32M24 52h16" stroke="currentColor" stroke-width="2"/>`,
  default: `<circle cx="32" cy="32" r="28" stroke="currentColor" stroke-width="2"/>
            <path d="M32 16v32M16 32h32" stroke="currentColor" stroke-width="2"/>`
};

const iconContent = icons[icon] || icons.default;
---

<div class="service-card" data-animate="fade-up" data-delay={delay}>
    <div class="service-icon">
        <svg viewBox="0 0 64 64" fill="none">
            <defs>
                <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#0a5694"/>
                    <stop offset="100%" style="stop-color:#171e60"/>
                </linearGradient>
            </defs>
            <Fragment set:html={iconContent} />
        </svg>
    </div>
    <h3>{title}</h3>
    <p>{description}</p>
    <ul class="service-features">
        {features.map((feature) => (
            <li>{feature}</li>
        ))}
    </ul>
    <a href={href} class="btn btn-secondary">Learn More</a>
</div>
