---
import settings from '../data/settings.json';
---

<section class="cta-section" id="book">
    <div class="cta-bg">
        <div class="cta-orb cta-orb-1"></div>
        <div class="cta-orb cta-orb-2"></div>
    </div>
    <div class="container">
        <div class="cta-content" data-animate="fade-up">
            <h2>Ready to Restore <span class="gradient-text">Your Health?</span></h2>
            <p>Take the first step toward naturally restored health. Schedule your evaluation online and create your personalized treatment plan.</p>
            <a href={settings.scheduleUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
                <span>Schedule My Evaluation</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
            </a>
            <p style="margin-top: var(--space-md);">
                Already a patient?
                <a href={settings.portalUrl} target="_blank" rel="noopener noreferrer" style="color: var(--color-primary);">Log in to the Patient Portal</a>
            </p>
        </div>
    </div>
</section>
